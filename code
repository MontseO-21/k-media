    "# Tomar las mismas observaciones pero convertirlas a un objeto de numpy\n",
    "x = dataset.iloc[:, 0:4].to_numpy()\n",
    "for j in range(2, 12): #probar diferentes números de grupos para ver cuál es el más adecuado\n",
    "    kmeans = KMeans(n_clusters = j, random_state = 42) #pruebas con un número distinto de grupos\n",
    "    #prediccion para cada punto\n",
    "    kmeans.fit_predict(x)\n",
    "    #calculamos el score de silueta, calidad de un clúster\n",
    "    score = silhouette_score(x, kmeans.labels_ , metric = 'euclidean') #qué tan bien definidos están los clústeres\n",
    "    #valores cercanos a 1 son los clústeres están bien separados y compactos, valores cercamos a 0 los clústeres se mezclan\n",
    "    # en este caso el valor óptimo de clusters es 5 como lo habíamos dicho\n",
    "    print(\"Score silhouette;\", \"k = \", j, \":\", score)"
   ]
