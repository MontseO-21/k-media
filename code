   "source": [
    "#calcular la inercia que hay en los puntos para k-means\n",
    "\n",
    "wcss = []\n",
    "for index in range (1,11): #hacer una prueba de hasta 11 clusters (grupos en total que convengan)\n",
    "    kmeans = KMeans(n_clusters = index, init = \"k-means++\", random_state = 2) # número de cluster\n",
    "    kmeans.fit(fields) #toma la lista de valores a que especifico grupo pertenecerá cada grupo\n",
    "    wcss.append(kmeans.inertia_) \n"
   ]
